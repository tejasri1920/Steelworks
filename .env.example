# .env.example
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control — it contains secrets.
# .env is already listed in .gitignore.

# ── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=steelworks_user           # DB username (change for production)
POSTGRES_PASSWORD=change_me_in_prod     # DB password  ← MUST CHANGE
POSTGRES_DB=steelworks_ops              # Database name
POSTGRES_PORT=5432                      # Host port mapped to the DB container

# ── Backend ──────────────────────────────────────────────────────────────────
# Full SQLAlchemy connection URL — auto-assembled in docker-compose.yml.
# Set this directly if running the backend without Docker.
DATABASE_URL=postgresql://steelworks_user:change_me_in_prod@localhost:5432/steelworks_ops

BACKEND_PORT=8000                       # Host port for the FastAPI container
LOG_LEVEL=info                          # uvicorn log level: debug | info | warning | error

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins that the backend will allow in CORS headers.
# Add your deployed frontend URL here once on a real server.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000                      # Host port for the Nginx/React container
# URL the browser uses to reach the backend API.
# In Docker Compose, keep this as localhost. On a real server, use the server IP/domain.
VITE_API_BASE_URL=http://localhost:8000
